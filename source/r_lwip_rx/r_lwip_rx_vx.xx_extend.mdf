            <option id="ACD_DEBUG.LWIP_DBG_ON" display="LWIP_DBG_ON" value="LWIP_DBG_ON"/>
            <description>Selects whether to enable or disable debugging in acd.c.
LWIP_DBG_OFF: Disabled; LWIP_DBG_ON: Enabled</description>
        </property>
        <property id="DNS_DEBUG" display="DNS_DEBUG" default="LWIP_DBG_OFF" type="checkbox" category="LWIP_DEBUG">
            <option id="DNS_DEBUG.LWIP_DBG_OFF" display="LWIP_DBG_OFF" value="LWIP_DBG_OFF"/>
            <option id="DNS_DEBUG.LWIP_DBG_ON" display="LWIP_DBG_ON" value="LWIP_DBG_ON"/>
            <description>Selects whether to enable or disable debugging for DNS.
LWIP_DBG_OFF: Disabled; LWIP_DBG_ON: Enabled</description>
        </property>
        <property id="IP6_DEBUG" display="IP6_DEBUG" default="LWIP_DBG_OFF" type="checkbox" category="LWIP_DEBUG">
            <option id="IP6_DEBUG.LWIP_DBG_OFF" display="LWIP_DBG_OFF" value="LWIP_DBG_OFF"/>
            <option id="IP6_DEBUG.LWIP_DBG_ON" display="LWIP_DBG_ON" value="LWIP_DBG_ON"/>
            <description>Selects whether to enable or disable debugging for IPv6.
LWIP_DBG_OFF: Disabled; LWIP_DBG_ON: Enabled</description>
        </property>
        <property id="DHCP6_DEBUG" display="DHCP6_DEBUG" default="LWIP_DBG_OFF" type="checkbox" category="LWIP_DEBUG">
            <option id="DHCP6_DEBUG.LWIP_DBG_OFF" display="LWIP_DBG_OFF" value="LWIP_DBG_OFF"/>
            <option id="DHCP6_DEBUG.LWIP_DBG_ON" display="LWIP_DBG_ON" value="LWIP_DBG_ON"/>
            <description>Selects whether to enable or disable debugging in dhcp6.c.
LWIP_DBG_OFF: Disabled; LWIP_DBG_ON: Enabled</description>
        </property>
        <property id="LWIP_PERF" display="LWIP_PERF" default="0" type="checkbox" category="LWIP_DEBUG">
            <option id="LWIP_PERF.0" display="Disabled" value="0"/>
            <option id="LWIP_PERF.1" display="Enabled" value="1"/>
            <description>Selects whether to enable or disable performance testing for lwIP.
LWIP_DBG_OFF: Disabled; LWIP_DBG_ON: Enabled</description>
        </property>
    </configuration>
</module>
