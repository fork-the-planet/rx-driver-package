            <option id="LWIP_DBG_TYPES_ON.LWIP_DBG_FRESH" display="LWIP_DBG_FRESH" value="LWIP_DBG_FRESH"/>
            <option id="LWIP_DBG_TYPES_ON.LWIP_DBG_HALT" display="LWIP_DBG_HALT" value="LWIP_DBG_HALT"/>
            <description>Sets a mask that can be used to globally enable/disable debug messages of certain types. Multiple values can be specified using the bitwise OR operator.
